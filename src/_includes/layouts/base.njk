<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title %}{{ title }} | {% endif %}Retire Right, Retire Now by Mike Stevens | Your Retirement Money Map</title>
    <meta name="description" content="{% if description %}{{ description }}{% else %}Turn your savings into a clear retirement strategy. Learn the five-pillar Retirement Money Map framework from fiduciary advisor Mike Stevens.{% endif %}">
    <meta name="author" content="Michael Stevens">
    <meta name="keywords" content="retirement planning, retire right, retirement book, fiduciary advisor, retirement income, tax planning retirement, Mike Stevens, Capital Wealth">
    
    <!-- Canonical URL -->
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    
    <!-- Open Graph -->
    <meta property="og:title" content="{% if title %}{{ title }} | {% endif %}{{ site.title }}">
    <meta property="og:description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">
    <meta property="og:type" content="{% if page.url == '/' %}website{% else %}article{% endif %}">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:site_name" content="{{ site.title }}">
    <meta property="og:image" content="{{ site.url }}/assets/images/book/ebook-cover.jpg">
    <meta property="og:image:alt" content="Retire Right, Retire Now book cover by Mike Stevens">
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{% if title %}{{ title }} | {% endif %}{{ site.title }}">
    <meta name="twitter:description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">
    <meta name="twitter:image" content="{{ site.url }}/assets/images/book/ebook-cover.jpg">
    <meta name="twitter:image:alt" content="Retire Right, Retire Now book cover by Mike Stevens">
    
    <!-- Google Fonts — TODO: Replace with self-hosted Glacial Indifference + Myriad Pro per brand guidelines -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700;800;900&family=Source+Sans+3:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Styles -->
    <link rel="stylesheet" href="/assets/css/main.css">
    
    <!-- Schema.org Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "{{ site.url }}/#website",
          "url": "{{ site.url }}/",
          "name": "{{ site.title }}",
          "description": "Turn your savings into a clear retirement strategy. Learn the five-pillar Retirement Money Map framework from fiduciary advisor Mike Stevens.",
          "publisher": {
            "@id": "{{ site.url }}/#person"
          },
          "potentialAction": {
            "@type": "SearchAction",
            "target": {
              "@type": "EntryPoint",
              "urlTemplate": "{{ site.url }}/search?q={search_term_string}"
            },
            "query-input": "required name=search_term_string"
          }
        },
        {
          "@type": "Person",
          "@id": "{{ site.url }}/#person",
          "name": "Michael Stevens",
          "alternateName": "Mike Stevens",
          "jobTitle": "President of Capital Wealth Advisors",
          "description": "Fiduciary financial advisor, founder of Capital Wealth Advisors, host of Retire Right Radio, with 25+ years experience in retirement planning",
          "knowsAbout": ["Retirement Planning", "Income Planning", "Tax-Efficient Withdrawal", "Healthcare Cost Planning", "Estate Planning", "Legacy Planning", "Fiduciary Advice"],
          "worksFor": {
            "@id": "{{ site.url }}/#capitalwealth"
          },
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Lehi",
            "addressRegion": "Utah"
          },
          "sameAs": [
            "{{ site.author.linkedin }}",
            "https://capitalwealth.com/radio/"
          ],
          "hasCredential": [
            {
              "@type": "EducationalOccupationalCredential",
              "credentialCategory": "Professional Certification",
              "name": "Fiduciary Financial Advisor"
            }
          ]
        },
        {
          "@type": "Book",
          "@id": "{{ site.url }}/#book",
          "name": "Retire Right, Retire Now",
          "alternativeHeadline": "Your Retirement Money Map",
          "author": {
            "@id": "{{ site.url }}/#person"
          },
          "description": "Turn your savings into a clear retirement strategy. Learn the five-pillar Retirement Money Map framework from practicing fiduciary advisor Mike Stevens.",
          "publisher": {
            "@id": "{{ site.url }}/#publisher"
          },
          "datePublished": "2026-04-01",
          "bookFormat": "EBook",
          "additionalProperty": [
            {
              "@type": "PropertyValue", 
              "name": "Target Audience",
              "value": "Pre-retirees within 10 years of retirement, Recently retired individuals, People with savings but no coordinated plan"
            }
          ],
          "about": [
            "Retirement Planning",
            "Income Planning", 
            "Tax-Efficient Withdrawal",
            "Healthcare Cost Planning",
            "Estate Planning"
          ],
          "genre": "Personal Finance",
          "inLanguage": "en-US"
        },
        {
          "@type": "Organization",
          "@id": "{{ site.url }}/#capitalwealth",
          "name": "Capital Wealth Advisors",
          "url": "https://capitalwealth.com",
          "logo": "https://capitalwealth.com/logo.png",
          "description": "Fiduciary financial advisory firm specializing in retirement planning",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Lehi",
            "addressRegion": "UT",
            "addressCountry": "US"
          },
          "founder": {
            "@id": "{{ site.url }}/#person"
          },
          "areaServed": "United States",
          "serviceType": "Financial Advisory Services"
        },
        {
          "@type": "Organization",
          "@id": "{{ site.url }}/#publisher",
          "name": "Capital Wealth Media, LLC",
          "description": "Publishing company for financial education content",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Lehi",
            "addressRegion": "UT", 
            "addressCountry": "US"
          }
        },
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Home",
              "item": "{{ site.url }}"
            }{% if page.url != '/' %},
            {
              "@type": "ListItem", 
              "position": 2,
              "name": "{% if title %}{{ title }}{% else %}{{ page.fileSlug | title }}{% endif %}",
              "item": "{{ site.url }}{{ page.url }}"
            }{% endif %}
          ]
        }{% if page.url == '/' %},
        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "What will I learn from Retire Right, Retire Now?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "You'll learn the five-pillar Retirement Money Map framework, including how to create reliable income streams, plan for healthcare costs, optimize taxes in retirement, protect against market volatility, design your estate plan, and ensure your money lasts throughout retirement."
              }
            },
            {
              "@type": "Question", 
              "name": "Who is Retire Right, Retire Now for?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "This book is for pre-retirees within 10 years of retirement, recently retired individuals, people with savings but no coordinated plan, and families seeking financial clarity. Whether you have $100,000 or $1 million saved, the principles apply."
              }
            },
            {
              "@type": "Question",
              "name": "Who is Mike Stevens?", 
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Mike Stevens is a fiduciary financial advisor, President of Capital Wealth Advisors, and host of Retire Right Radio. With 25+ years of experience, he helps people transition from accumulation to distribution in retirement planning."
              }
            },
            {
              "@type": "Question",
              "name": "When will Retire Right, Retire Now be available?",
              "acceptedAnswer": {
                "@type": "Answer", 
                "text": "Retire Right, Retire Now is scheduled for release in Spring 2026. You can get your free chapter now and be notified when the full book is available."
              }
            },
            {
              "@type": "Question",
              "name": "Is this book only for wealthy people?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "No, the principles in Retire Right, Retire Now apply at any savings level. Good retirement planning is about percentages and strategies, not just dollar amounts. Whether you have $100,000 or $1 million saved, you'll benefit from the framework."
              }
            }
          ]
        }
        {% endif %}
      ]
    }
    </script>
</head>
<body>
    <!-- Navigation -->
    <header class="header">
        <div class="container">
            <nav class="nav" aria-label="Main navigation">
                <div class="nav-brand">
                    <a href="/" class="logo">{{ site.title }}</a>
                </div>
                
                <div class="nav-links" aria-label="Page sections">
                    <a href="#learn">What You'll Learn</a>
                    <a href="#author">About Mike</a>
                    <a href="#ready-to-act">Get Free Chapter</a>
                </div>
                
                <a href="#free-chapter" class="btn btn-secondary">Get Free Chapter</a>
                
                <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </nav>
        </div>
    </header>

    <!-- Main Content -->
    <main>
        {{ content | safe }}
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-links">
                    <a href="https://capitalwealth.com" target="_blank" rel="noopener">Capital Wealth</a>
                    <a href="{{ site.author.linkedin }}" target="_blank" rel="noopener">LinkedIn</a>
                    <a href="https://capitalwealth.com/radio/" target="_blank" rel="noopener">Retire Right Radio</a>
                </div>
                
                <div class="footer-legal">
                    <p>&copy; 2026 Capital Wealth Media, LLC. All rights reserved.</p>
                    <p class="footer-credit">Built by <a href="https://gullstack.com" target="_blank" rel="noopener">GullStack</a></p>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="/assets/js/main.js"></script>
</body>
</html>